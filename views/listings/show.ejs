<%- layout("layouts/boilerplate.ejs") %>

    <body>
        <script>
            const map_token = "<%=process.env.MAP_TOKEN%>";
            const listing = <%- JSON.stringify(listing) %>
       </script>
        <h1 style="margin-top: 2rem; margin-bottom: 1rem;">
            <%= listing.title %>
        </h1>
        <h2 style="margin-bottom: 1rem;">Owner >> <%= listing.ownerUsername %>
        </h2>
        <img alt="Image" src="<%= listing.image.url%>" class="showimg">
        <div class="detail">
            <ul>
                <li >
                    <%= listing.description %>
                </li>
                <li>&#8377; <%= listing.price.toLocaleString("en-IN") %>
                </li>
                <li>
                    <%= listing.location %>
                </li>
                <li>
                    <%= listing.country %>
                </li>

            </ul>
           
        </div>

        <%if(currUser && String(currUser._id) === String(listing.ownerId)){ %>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn"><a href="/listings/<%= listing._id %>/edit">Edit</a></button>
                <button class="btn">Delete</button>
            </form>

            <%}%>

            

                <% if(currUser){ %>
                    <hr>
            <div style="height: 1px; background: #000; width: 50%;"></div>
            <hr>
                    <div  class="LeaveSection" >
                        <h2 style="align-self: center;">Leave a Review</h2>
                        <form class="submitReview" method="POST" action="/listings/<%= listing._id%>/reviews">
                            
                                <fieldset class="starability-grow" >
                                    <p style="margin-bottom: 0.6rem; font-size: 1.4rem; "> Rating:</p>
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                  </fieldset>

                           
                            <div style="display: flex; align-items: start; gap: 10px;">
                                <label for="comment" >Comment</label>
                                <textarea style="padding: 0.5rem; font-size: 1rem;" name="review[comment]" id="comment" rows="4" cols="20" required ></textarea>
                            </div>
                            <button class="btn" style="height: 3rem; width: 6rem; padding: 0; margin: 0;">Submit</button>

                        </form>

                    </div>
                    <% }%>

                        <hr>
                        <div style="height: 1px; background: #000; width: 50%;"></div>
                        <hr>
                        <%if(reviews.length>0){ %>
                        <div class="LeaveSection" >
                            <h2 style="align-self: center;">Reviews</h2>
                            <ul class="Reviewlist ">
                                <% for (review of reviews) { %>
                                    <div class="eachReview">
                                        <h3>Author : <%= review.authorUsername %></h3>
                                        <p style="overflow-wrap:anywhere;"><%= review.comment%></p> 
                                        <p class="starability-result" data-rating="<%=review.rating%>">
                                        </p>    
             

                                    <form method="POST"
                                        action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                                        <button class="btn" style=" padding: 0.3rem; margin: 0;">Delete</button>
                                    </form>
                                        
                                    </div>
                                      
                                    <%}%>
                            </ul>
                            </p>
                        </div>
                    <%}%>
                    <div id="map"></div>

    <script src="/js/map.js"></script>
                        
    </body>
   

# Root env for docker-compose (copy to .env and fill in). Compose interpolates ${VARS}.
# The .env file is gitignored — never commit real secrets.

# Shared JWT secret (gateway verifies, user-service signs) — must be identical everywhere it's used
JWT_SECRET=change-me-to-a-long-random-string

# Database-per-service (separate databases in one MongoDB Atlas cluster)
USERS_DB_URL=mongodb+srv://<user>:<pass>@<cluster>/wanderlust_users?retryWrites=true&w=majority
LISTINGS_DB_URL=mongodb+srv://<user>:<pass>@<cluster>/wanderlust_listings?retryWrites=true&w=majority
REVIEWS_DB_URL=mongodb+srv://<user>:<pass>@<cluster>/wanderlust_reviews?retryWrites=true&w=majority

# Mapbox (geocoding server-side in listing-service; map render client-side via gateway)
MAP_TOKEN=pk.your_mapbox_public_token

# Cloudinary (image uploads — used by listing-service)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

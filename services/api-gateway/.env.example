# API Gateway configuration (copy to .env and fill in)
PORT=8080

# Gateway still owns the listings + reviews data until Phase 3
MONGO_URL=mongodb+srv://<user>:<pass>@<cluster>/wanderlust?retryWrites=true&w=majority

# Must match the user-service JWT_SECRET (gateway verifies, user-service signs)
JWT_SECRET=change-me-to-a-long-random-string

# Where the user-service is reachable
USER_SERVICE_URL=http://localhost:4001

# Listing dependencies (Mapbox geocoding + Cloudinary uploads)
MAP_TOKEN=pk.your_mapbox_public_token
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

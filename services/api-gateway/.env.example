# API Gateway configuration (copy to .env and fill in)
PORT=8080

# The gateway is stateless — it owns no database. It routes/aggregates across services.
# Must match every service's JWT_SECRET (gateway verifies, user-service signs)
JWT_SECRET=change-me-to-a-long-random-string

# Where the domain services are reachable
USER_SERVICE_URL=http://localhost:4001
LISTING_SERVICE_URL=http://localhost:4002
REVIEW_SERVICE_URL=http://localhost:4003

# Public Mapbox token — used ONLY to render the client-side map on the show page
MAP_TOKEN=pk.your_mapbox_public_token

# User / Auth service configuration (copy to .env and fill in)
PORT=4001

# The user-service owns its OWN database (database-per-service)
USERS_DB_URL=mongodb+srv://<user>:<pass>@<cluster>/wanderlust_users?retryWrites=true&w=majority

# Must match the gateway JWT_SECRET (user-service signs, gateway verifies)
JWT_SECRET=change-me-to-a-long-random-string

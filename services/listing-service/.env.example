# Listing service configuration (copy to .env and fill in)
PORT=4002

# The listing-service owns its OWN database (database-per-service)
LISTINGS_DB_URL=mongodb+srv://<user>:<pass>@<cluster>/wanderlust_listings?retryWrites=true&w=majority

# Where the review-service is reachable (for cascade delete)
REVIEW_SERVICE_URL=http://localhost:4003

# Mapbox geocoding + Cloudinary uploads
MAP_TOKEN=pk.your_mapbox_public_token
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret
